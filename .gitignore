# ============================================================
# ACADEMIC CAMPASS 2025 — .gitignore
# ============================================================

# ─── Next.js ────────────────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts

# ─── Node ────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environment / Secrets ───────────────────────────────────
.env
.env.*
!.env.example

# ─── TypeScript build info ───────────────────────────────────
*.tsbuildinfo

# ─── Logs ────────────────────────────────────────────────────
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Python ──────────────────────────────────────────────────
/venv/
__pycache__/
*.py[cod]
/requirements.txt

# ─── Testing / Coverage ──────────────────────────────────────
/coverage/
*.lcov
.nyc_output

# ─── Cache ───────────────────────────────────────────────────
.cache
.parcel-cache
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ─── OS files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
*~

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Runtime data ────────────────────────────────────────────
pids
*.pid
*.seed
*.pid.lock

# ─── Misc ────────────────────────────────────────────────────
*.pem
*.tgz
*.db
*.sqlite
*.sqlite3
*.bak
*.backup
*.zip
*.tar.gz
*.rar
.npm
.node_repl_history
.yarn-integrity
tmp/
temp/

# ─── Supabase ────────────────────────────────────────────────
.supabase

# ─── Vercel ──────────────────────────────────────────────────
.vercel




