# ============================================================
# ALGOMATE - Environment Variables Template
# ============================================================
# Copy this file to .env.local for development
# Never commit actual .env files to git!
# ============================================================

# ─── Database (Neon PostgreSQL) ─────────────────────────────
# Get this from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Python Backend API (Railway) ───────────────────────────
# Local development: http://localhost:8001
# Production: Your Railway deployment URL
SCHEDULER_API_URL=http://localhost:8001

# ─── Frontend Configuration ─────────────────────────────────
# Local: http://localhost:3000
# Production: Your Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Redis Cache (Upstash) ──────────────────────────────────
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Authentication Secrets ─────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_32_chars_minimum
NEXTAUTH_SECRET=your_nextauth_secret_32_chars_min
NEXTAUTH_URL=http://localhost:3000

# ─── Email Configuration (Nodemailer) ───────────────────────
# For Gmail: Use App-specific password (not your regular password)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM="Algomate <noreply@yourdomain.com>"

# ─── Supabase (Optional - if using Supabase features) ───────
# Only needed if using Supabase-specific features
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_anon_public_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Python Backend Configuration ───────────────────────────
# Used by FastAPI scheduler
SCHEDULER_PROFILE=development
PYTHONUNBUFFERED=1

# ─── Optional: Analytics & Monitoring ───────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# VERCEL_ANALYTICS_ID=your_analytics_id

# ─── Optional: Feature Flags ────────────────────────────────
# ENABLE_NEP_SCHEDULER=true
# ENABLE_AI_TIMETABLE=true
# ENABLE_ASSIGNMENTS=true

# ─── Development Only ───────────────────────────────────────
# NODE_ENV=development
# LOG_LEVEL=debug
