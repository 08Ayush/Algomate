"""Example configuration file for ensemble scheduler."""

{
  "parallel_execution": true,
  "max_workers": 3,
  "voting_strategy": "weighted",
  
  "cpsat": {
    "name": "cpsat",
    "enabled": true,
    "weight": 0.70,
    "timeout_seconds": 300,
    "parameters": {
      "num_search_workers": 8,
      "max_time_in_seconds": 300,
      "random_seed": 42
    }
  },
  
  "tabu": {
    "name": "tabu",
    "enabled": true,
    "weight": 0.20,
    "timeout_seconds": 180,
    "parameters": {
      "tabu_tenure": 10,
      "max_iterations": 1000,
      "aspiration_threshold": 0.95
    }
  },
  
  "vns": {
    "name": "vns",
    "enabled": true,
    "weight": 0.10,
    "timeout_seconds": 180,
    "parameters": {
      "neighborhood_sizes": [1, 2, 3, 5],
      "max_iterations": 500,
      "shake_intensity": 0.3
    }
  },
  
  "ml": {
    "enabled": true,
    "model_path": "models/quality_predictor.pkl",
    "patterns_path": "models/patterns.json",
    "feature_count": 89,
    "feature_normalization": true,
    "n_estimators": 100,
    "learning_rate": 0.1,
    "max_depth": 5,
    "update_threshold": 50,
    "retrain_on_startup": false
  },
  
  "database": {
    "cache_enabled": true,
    "cache_ttl": 3600,
    "timeout": 30,
    "max_retries": 3
  },
  
  "log_level": "INFO",
  "log_to_file": true,
  "solution_cache_size": 100,
  "enable_profiling": false
}
